<UserControl x:Class="Tab_Elements"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PolyCut"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DesignHeight="800"
             d:DesignWidth="380"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Separator Grid.Row="0" Margin="5" />


        <ScrollViewer Grid.Row="3"
                      Margin="-14 0 -14 0" Padding="10 0 25 0"
                      CanContentScroll="True" VerticalScrollBarVisibility="Visible">

            <ui:ListView x:Name="FilesList" FocusVisualStyle="{x:Null}" 
                         VerticalAlignment="Top"
                         ItemsSource="{Binding MainVM.FlatSidebarItems}"
                         SelectionChanged="ListView_SelectionChanged" SelectionMode="Extended">

                <ui:ListView.Resources>
                    <!--  Default / fallback (Group / unknown)  -->

                    <Style x:Key="DrawableIconStyle" TargetType="ui:SymbolIcon">
                        <!--  default color  -->
                        <Setter Property="Foreground" Value="{StaticResource TextFillColorSecondaryBrush}" />

                        <Style.Triggers>
                            <!--  when row selected  -->
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource PaletteBlueBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>

                    <DataTemplate DataType="{x:Type local:DrawableEllipse}">
                        <ui:SymbolIcon Filled="True" FontSize="20"
                                       Style="{StaticResource DrawableIconStyle}"
                                       Symbol="Circle24" />
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type local:DrawableRectangle}">
                        <ui:SymbolIcon Filled="True" FontSize="20"
                                       Style="{StaticResource DrawableIconStyle}"
                                       Symbol="Square24" />
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type local:DrawableLine}">
                        <ui:SymbolIcon Filled="True" FontSize="20"
                                       Style="{StaticResource DrawableIconStyle}"
                                       Symbol="Line24" />
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type local:DrawablePath}">
                        <ui:SymbolIcon Filled="True" FontSize="20"
                                       Style="{StaticResource DrawableIconStyle}"
                                       Symbol="Pentagon20" />
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type local:DrawableText}">
                        <ui:SymbolIcon Filled="True" FontSize="20"
                                       Style="{StaticResource DrawableIconStyle}"
                                       Symbol="Text16" />
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type local:NestedDrawableGroup}">
                        <ui:SymbolIcon Filled="True" FontSize="23"
                                       Style="{StaticResource DrawableIconStyle}"
                                       Symbol="Shapes20" />
                    </DataTemplate>
                </ui:ListView.Resources>

                <ui:ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border Margin="0 5 0 5" Background="{TemplateBinding Background}">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ui:ListView.ItemContainerStyle>

                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="25" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="20" />
                            </Grid.RowDefinitions>

                            <Border x:Name="ContainingGrid"
                                    Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="6"
                                    CornerRadius="5">
                                <Border.Background>
                                    <LinearGradientBrush Opacity="0" StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0.4" Color="#FFFFFFFF" />
                                        <GradientStop Offset="1" Color="#FFFFFFFF" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!--  Selection bar  -->
                            <Border Grid.RowSpan="2" Grid.Column="0"
                                    Width="2"
                                    Margin="-4 5 0 5"
                                    Background="{StaticResource PaletteBlueBrush}"
                                    CornerRadius="2"
                                    Visibility="{Binding Item.IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ContentControl Grid.RowSpan="2" Grid.Column="1"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                            Content="{Binding Item}" />

                            <!--  Eye toggle now binds to the wrapped child  -->
                            <ToggleButton Grid.RowSpan="2" Grid.Column="5" IsChecked="{Binding Item.IsHidden}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">

                                        <ui:Card x:Name="IconCard"
                                                 Padding="5 4 5 0"
                                                 Background="Transparent"
                                                 BorderBrush="{StaticResource ControlAltFillColorDisabledBrush}"
                                                 Opacity="0">
                                            <ui:SymbolIcon x:Name="Icon" Filled="True" Symbol="Eye48" />
                                        </ui:Card>

                                        <ControlTemplate.Triggers>

                                            <!--  Hidden => EyeOff + always visible  -->
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Icon" Property="Symbol" Value="EyeOff24" />
                                                <Setter TargetName="IconCard" Property="Opacity" Value="1" />
                                            </Trigger>

                                            <!--  Visible => Eye icon, default hidden  -->
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="Icon" Property="Symbol" Value="Eye48" />
                                                <Setter TargetName="IconCard" Property="Opacity" Value="0" />
                                            </Trigger>

                                            <!--  On row hover, show the icon (but only applies when IsChecked=False because the above trigger sets opacity)  -->
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                <Setter TargetName="IconCard" Property="Opacity" Value="1" />
                                            </DataTrigger>

                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!--  Main text + parent "pill"  -->
                            <StackPanel Grid.Column="3"
                                        Margin="0 5" VerticalAlignment="Center"
                                        Orientation="Horizontal">

                                <TextBlock VerticalAlignment="Center" Text="{Binding Item.Name}" />

                                <!--<Border Margin="5 0" Padding="10 2" VerticalAlignment="Center"
                                        Background="{StaticResource CardBackground}"
                                        CornerRadius="4">
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="10" FontWeight="Thin"
                                               Text="{Binding Item.VisualName}" />
                                </Border>-->

                            </StackPanel>


                            <TextBlock Grid.Row="2" Grid.Column="3"
                                       VerticalAlignment="Top" 
                                       FontSize="11" Foreground="#60FFFFFF"
                                       Text="{Binding ParentName}" />

                        </Grid>

                        <DataTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContainingGrid" Storyboard.TargetProperty="(Grid.Background).(LinearGradientBrush.Opacity)" To="0.11" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContainingGrid" Storyboard.TargetProperty="(Grid.Background).(LinearGradientBrush.Opacity)" To="0" Duration="0:0:0.05" />

                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>

        </ScrollViewer>
        <Separator Grid.Row="4" Margin="5" Visibility="{Binding MainVM.HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <Grid Grid.Row="5" Margin="10 0 10 -10" Visibility="{Binding MainVM.HasSelection, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <!--<ui:Button Height="40" HorizontalAlignment="Right"
                       Margin="0 0 5 0" Padding="6"
                       Background="Transparent"
                       Command="{Binding MainVM.BrowseSVGCommand}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add12" />
                    <TextBlock Margin="10 0" VerticalAlignment="Center" Text="Import SVG" />
                </StackPanel>

            </ui:Button>-->

            <ui:Button Grid.Column="3"
                       Width="65" Height="40"
                       Margin="20 0 0 0" Padding="0"
                       Background="Transparent" BorderThickness="0"
                       Command="{Binding DeleteDrawableElementCommand}"
                       >
                <StackPanel Orientation="Vertical">
                    <ui:SymbolIcon FontSize="16" Symbol="Delete20" />
                    <TextBlock FontSize="9" Text="Delete" />
                </StackPanel>


            </ui:Button>

            <ui:DropDownButton Grid.Column="0"
                               Width="65" Height="40"
                               Padding="0"
                               Background="Transparent" BorderThickness="0">
                <ui:DropDownButton.Content>
                    <StackPanel Orientation="Vertical">
                        <ui:SymbolIcon FontSize="16" Symbol="ShapeIntersect16" />
                        <TextBlock FontSize="9" Text="Combine" />
                    </StackPanel>
                </ui:DropDownButton.Content>

                <ui:DropDownButton.Flyout>
                    <ContextMenu>
                        <MenuItem Header="Union" Icon="{ui:SymbolIcon Symbol=ShapeUnion20}" Command="{Binding MainVM.UnionShapesCommand}" />
                        <MenuItem Header="Intersect" Icon="{ui:SymbolIcon Symbol=ShapeIntersect20}" Command="{Binding MainVM.IntersectShapesCommand}"/>
                        <MenuItem Header="Subtract" Icon="{ui:SymbolIcon Symbol=ShapeSubtract20}" Command="{Binding MainVM.SubtractShapesCommand}"/>
                        <MenuItem Header="Exclude" Icon="{ui:SymbolIcon Symbol=ShapeExclude20}" Command="{Binding MainVM.XorShapesCommand}"/>
                    </ContextMenu>
                </ui:DropDownButton.Flyout>

            </ui:DropDownButton>


        </Grid>

    </Grid>
</UserControl>
